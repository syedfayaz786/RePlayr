# ─────────────────────────────────────────────────────────────────
# RePlayr — Environment Variables
# Copy this file to .env.local and fill in all required values.
# ─────────────────────────────────────────────────────────────────

# ── Database (PostgreSQL required) ───────────────────────────────
# Local development: use a local Postgres instance
# DATABASE_URL="postgresql://postgres:password@localhost:5432/replayr"
#
# Supabase (recommended for production):
# Get your connection string from: https://supabase.com/dashboard/project/_/settings/database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Only needed for Supabase connection pooling (pgBouncer). Leave blank for local dev.
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# ── NextAuth.js ───────────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth (optional) ───────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ── GitHub OAuth (optional) ───────────────────────────────────────
# Get from: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"
