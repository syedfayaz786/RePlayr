generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Uncomment and set DIRECT_URL if using Supabase connection pooling:
  // directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  location      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  listings         Listing[]
  wishlist         Wishlist[]
  reviewsGiven     Review[]          @relation("ReviewAuthor")
  reviewsReceived  Review[]          @relation("ReviewTarget")
  messagesSent     Message[]         @relation("MessageSender")
  messagesReceived Message[]         @relation("MessageReceiver")
  offers           Offer[]           @relation("OfferBuyer")
  listingOffers    Offer[]           @relation("OfferSeller")
  locationRequests LocationRequest[] @relation("LocationRequester")
  salesAsSeller    Sale[]            @relation("SaleSeller")
  salesAsBuyer     Sale[]            @relation("SaleBuyer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Listing {
  id          String  @id @default(cuid())
  title       String
  description String?
  price       Float
  platform    String
  edition     String?
  condition   String
  images      String  @default("[]")

  // Human-readable label shown publicly e.g. "Chelsea, Manhattan, NY 10001"
  location String?

  // PRIVATE: exact geocoded coords — NEVER exposed to buyers via any API
  latitude  Float?
  longitude Float?

  // FUZZY: ±500 m randomised offset — the ONLY coords ever sent to buyers for the map circle
  fuzzyLat Float?
  fuzzyLng Float?

  status    String   @default("active")
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sellerId  String

  seller           User              @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  wishlistedBy     Wishlist[]
  offers           Offer[]
  messages         Message[]
  locationRequests LocationRequest[]
  sale             Sale?
  reviews          Review[]
}

// Buyer sends request → seller approves/denies → exact area shared via private message
model LocationRequest {
  id          String   @id @default(cuid())
  listingId   String
  requesterId String
  status      String   @default("pending") // pending | approved | denied
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  requester User    @relation("LocationRequester", fields: [requesterId], references: [id])

  @@unique([listingId, requesterId])
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  @@unique([userId, listingId])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int
  comment   String?
  strengths String   @default("[]")  // JSON array of preset phrase strings
  authorId  String
  targetId  String
  listingId String?
  role      String   @default("buyer")  // "buyer" | "seller" — role of the AUTHOR when reviewing
  createdAt DateTime @default(now())
  author    User     @relation("ReviewAuthor", fields: [authorId], references: [id])
  target    User     @relation("ReviewTarget", fields: [targetId], references: [id])
  listing   Listing? @relation(fields: [listingId], references: [id])

  @@unique([authorId, listingId])  // one review per user per listing
}

model Offer {
  id        String   @id @default(cuid())
  amount    Float
  message   String?
  status    String   @default("pending")
  listingId String
  buyerId   String
  sellerId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer     User     @relation("OfferBuyer", fields: [buyerId], references: [id])
  seller    User     @relation("OfferSeller", fields: [sellerId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  content    String
  senderId   String
  receiverId String
  listingId  String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  sender     User     @relation("MessageSender", fields: [senderId], references: [id])
  receiver   User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  listing    Listing? @relation(fields: [listingId], references: [id])
}

// Records the confirmed buyer for a listing — created when seller clicks "Sold to this buyer"
model Sale {
  id        String   @id @default(cuid())
  listingId String   @unique  // one sale per listing
  sellerId  String
  buyerId   String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  seller  User    @relation("SaleSeller", fields: [sellerId], references: [id])
  buyer   User    @relation("SaleBuyer",  fields: [buyerId],  references: [id])
}
